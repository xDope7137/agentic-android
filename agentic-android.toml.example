####################################################################
#  Agentic Android — settings.  Edit this file, then run:
#     python -m agentic_android
#
#  QUICK START
#  1) Set `provider` below to the brain you want.
#  2) Fill in that provider's section (api_key / model / base_url).
#  3) Set [device].serial to your phone/emulator (see: --list-devices).
#  4) Run `python -m agentic_android`.
####################################################################


# Which brain drives the phone?
#   "claude-cli" → use your logged-in `claude` CLI. NO API key needed. (live chat)
#   "anthropic"  → Anthropic API.            Needs [anthropic] api_key.
#   "openai"     → OpenAI API or ANY OpenAI-compatible server (local, OpenRouter,
#                  Azure, Groq, …).          Needs [openai] api_key + base_url.
provider = "claude-cli"


[device]
# Your device's adb id. Run `python -m agentic_android --list-devices` to find it.
# A networked emulator looks like "192.168.1.79:5555".
serial = ""                       # e.g. "192.168.1.79:5555" or a USB serial (see --list-devices)


[agent]
# HOW HARD the agent tries to fix things itself before stopping to ASK YOU a
# question (with options).  0 = ask early, 5 = try everything first.
#   0  ask at the first problem            (cheapest)
#   3  several recovery attempts (default)
#   5  exhaust every avenue; only ask for passwords / 2FA / purchases (priciest)
# COST: higher = more screenshots + model calls before it pauses = more $$$.
effort = 3
# Screenshots are downscaled so their long edge is at most this many pixels
# (smaller = cheaper/faster, less detail). 1568 is a good default.
max_long_edge = 1568
# Save every API request + response for a session to a file under debug/
# (one JSONL file per run). Handy for debugging; off by default. Same as --debug.
debug = true

# ---- Reliable Runs: self-checks & recovery (sensible defaults; rarely need changing) ----
# If a screenshot comes back blank/black (some app surfaces can't be captured),
# fall back to reading the screen from the UI element list instead of stalling.
auto_ui_fallback = true
# A screenshot smaller than this many PNG bytes is treated as blank/dead. A solid
# black screen is ~6 KB; a real screen is hundreds of KB. Lower it on very small
# screens; set 0 to disable blank detection entirely.
blank_png_bytes = 20000
# After each action, wait until the screen stops changing (up to settle_timeout)
# instead of a fixed pause — steadier on slow/animated screens. false = fixed sleep.
wait_idle = true
settle = 0.8            # fixed pause seconds, used only when wait_idle = false
settle_timeout = 4.0    # max seconds to wait for the screen to go idle
# Retry transient adb failures (a dropped/flaky connection) before giving up.
adb_retries = 2
adb_backoff = 0.5       # base backoff seconds (exponential)
adb_timeout = 60        # per-adb-command timeout (seconds)
# LLM call timeout/retries (anthropic & openai). Prevents hangs on a stalled API.
api_timeout = 120.0
api_retries = 2
# Pause and ask before HIGH-RISK actions (uninstall, buy/pay, delete, factory
# reset, sign out, …). Off by default so you aren't surprised; turn on for safety.
confirm_destructive = false
# Override the high-risk label list if you like (matched case-insensitively):
# destructive_keywords = ["uninstall", "delete", "buy", "pay", "factory reset"]

# ---- Onboarding: preflight checks (doctor) ----
# Run a quick check before each run (adb, device, screenshot, provider) and fail
# with a clear, fixable message instead of a cryptic error. `--doctor` runs the
# full report; `--no-preflight` skips this. preflight_screenshot adds the (slower)
# screenshot check to the auto-preflight.
preflight = true
preflight_screenshot = true
connect_timeout = 10.0   # bound `adb connect host:port`
# When no serial is set, use the sole attached device automatically (prompt if many).
auto_select_device = true

# ---- Skills: learn once, run free ----
# Record a task once, then replay it deterministically (~zero LLM cost):
#   python -m agentic_android --provider openai --record "open the clock app" --as clock
#   python -m agentic_android --run-skill clock        # replays with no LLM calls
skill_heal = true       # heal a drifted step with the LLM on replay (needs an API provider)
skill_shortcut = true   # try a mined `am start` shortcut to skip navigation on replay


# ---- Notification triggers: wake the agent on a phone notification ----
# Ask for a REACTIVE task in chat (e.g. "reply to WhatsApp messages from my boss"
# or "when my food delivery arrives, mark it received") and the agent offers to set
# up a trigger that binds that app's notifications to the task. While a chat session
# is open, a watcher polls notifications and feeds matching ones to the live agent.
#   python -m agentic_android --triggers      # list saved triggers
#   python -m agentic_android --no-triggers   # don't run the watcher this session
[triggers]
enabled = true          # run the inline notification watcher during chat
poll_interval_s = 8.0   # how often to check the phone for new notifications
# dir = "data/triggers" # where trigger definitions are stored (relative to project root)
cooldown_s = 15.0       # after firing, briefly ignore the burst the task may cause


# ---- Interactive CLI presentation ----
[ui]
mode = "auto"           # auto (rich if installed + a TTY) | rich | plain
inline_screen = "auto"  # auto | on | off — show the phone screen inline (kitty/iTerm2) each action
screen_max_cells = 40   # inline screenshot width in terminal cells


# ---- provider = "claude-cli" (recommended; no API key) -------------------
[claude_cli]
model = "claude-opus-4-8"   # most capable; or an alias: opus | sonnet | haiku
budget_usd = 0              # 0 = no spend cap
max_output_tokens = 32000   # high response cap for the chat (also raises MCP-output cap)


# ---- provider = "anthropic" ---------------------------------------------
[anthropic]
api_key = ""                       # or leave blank and set env ANTHROPIC_API_KEY
model   = "claude-opus-4-8"
vision  = false                    # images off for now (cheaper); see below


# ---- provider = "openai" (and OpenAI-compatible servers) ----------------
[openai]
api_key  = ""                            # or leave blank and set env OPENAI_API_KEY
# Change this to point at any OpenAI-compatible endpoint:
#   OpenAI            https://api.openai.com/v1
#   OpenRouter        https://openrouter.ai/api/v1
#   Local (Ollama)    http://localhost:11434/v1
#   LM Studio         http://localhost:1234/v1
base_url = "https://api.openai.com/v1"
model    = "gpt-4o-mini"

# Can your model SEE images?
#   true  → it gets screenshots (use a vision model like gpt-4o). Best results.
#   false → it CANNOT see images, so the agent describes the screen as a TEXT
#           list of on-screen buttons/fields with tap coordinates (built from the
#           Android UI tree). Use this for text-only models (most local LLMs).
#
# COST NOTE (measured on gpt-4o-mini): ONE screenshot ≈ 37,800 input tokens,
# while the text element list ≈ 2,200 — vision is ~17x pricier per screen and
# it compounds (every step resends past screenshots). Keep this false to save $$.
vision = true


# ---- provider = "ollama" (local model; free, runs on your machine) ------
# A local OpenAI-compatible server. Set provider = "ollama" above to use it.
# Needs no API key. The model must support tool/function calling (e.g. qwen3,
# llama3.1/3.2, mistral-nemo). Vision models (qwen3-vl, llava) can set vision=true.
[ollama]
base_url = "http://localhost:11434/v1"   # Ollama default
model    = ""                            # blank = auto-detect the loaded model
vision   = false                         # qwen3-vl etc. can do true (free locally)
# Context window. Ollama defaults to only 4096, which is too small for an agent.
# Set high since local tokens are free; lower it ONLY if you hit GPU/RAM limits
# (bigger context = more memory). Output length is uncapped for local models.
num_ctx  = 32768


# ---- provider = "lmstudio" (local model via LM Studio; free) ------------
# Start the server in LM Studio's "Developer" tab and load a model that supports
# tool calling (e.g. Gemma 4, Qwen, Llama 3.x). Set a generous context length
# when you load the model (LM Studio default is small) so long tasks don't get
# truncated. Set provider = "lmstudio" above to use it.
[lmstudio]
base_url = "http://localhost:1234/v1"    # LM Studio default
model    = ""                            # blank = auto-detect (skips embedding models)
vision   = false                         # multimodal models (Gemma 4, etc.) can do true


# ---- Pricing (USD per 1 MILLION tokens) ---------------------------------
# Used to print a cost estimate after each run. Common models are built in;
# add/override here (e.g. for a custom or local endpoint). cached_input is the
# discounted rate for prompt-cache hits.
[pricing]
"gpt-4o-mini" = { input = 0.15, output = 0.60, cached_input = 0.075 }
"gpt-4o"      = { input = 2.50, output = 10.0, cached_input = 1.25 }
# "my-local-model" = { input = 0.0, output = 0.0 }
