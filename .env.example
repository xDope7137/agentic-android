# Optional. Copy to .env (auto-loaded if python-dotenv is installed).
# .env is for SECRETS / env vars. Most settings (provider, model, effort, vision)
# live in agentic-android.toml — but these env vars also work and override the file.

# Pick the brain (or set `provider` in agentic-android.toml):
# AGENTIC_ANDROID_PROVIDER=openai          # claude-cli | anthropic | openai

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (or any OpenAI-compatible endpoint)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Pin a device when several are attached (see --list-devices)
# ANDROID_SERIAL=192.168.1.79:5555
